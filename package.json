{
  "name": "ember-codemod-pod-to-octane",
  "version": "5.1.1",
  "description": "Codemod to un-pod Ember apps, addons, and engines",
  "keywords": [
    "codemod",
    "ember-codemod",
    "ember-octane",
    "emberjs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ijlee2/ember-codemod-pod-to-octane.git"
  },
  "license": "MIT",
  "author": "Isaac J. Lee",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": "dist/bin/ember-codemod-pod-to-octane.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "sh build.sh --production",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "tsc --noEmit",
    "prepare": "pnpm build",
    "release:prepare": "changeset version",
    "release:publish": "pnpm build && changeset publish",
    "test": "sh build.sh --test && mt dist-for-testing --quiet"
  },
  "dependencies": {
    "@codemod-utils/files": "^4.1.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@codemod-utils/tests": "^3.1.0",
    "@ijlee2-frontend-configs/changesets": "^2.1.1",
    "@ijlee2-frontend-configs/eslint-config-node": "^4.1.0",
    "@ijlee2-frontend-configs/prettier": "^3.3.0",
    "@sondr3/minitest": "^0.1.2",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^22.20.0",
    "@types/yargs": "^17.0.35",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": "22.* || >= 24"
  }
}
